{
  "expo": {
    "name": "Hydra AI",
    "slug": "hydra-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hydra-ai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#042f4e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hydraai.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#042f4e"
      },
      "package": "com.hydraai.app",
      "permissions": ["VIBRATE", "RECEIVE_BOOT_COMPLETED"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0088d4"
        }
      ]
    ]
  }
}
