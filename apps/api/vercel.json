{
  "version": 2,
  "buildCommand": "npx prisma generate && npx tsc --project tsconfig.json",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
